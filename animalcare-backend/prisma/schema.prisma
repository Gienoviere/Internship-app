generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPERVISOR
  FARMER
  VOLUNTEER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(USER)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  logs         DailyLog[]
  reviewedLogs DailyLog[] @relation("ReviewedLogs")

  observations Observation[] @relation("UserObservations")

  taskAssignments TaskAssignment[]

  googleAccessToken String?
  googleRefreshToken String?
  googleExpiry DateTime?
}

model Task {
  id               Int              @id @default(autoincrement())
  name             String
  description      String?
  category         String?
  animalCategory   String?
  isDaily          Boolean          @default(true)
  sortOrder        Int              @default(0)
  active           Boolean          @default(true)
  affectsInventory Boolean          @default(false)
  feedItemId       Int?
  photoRequired    Boolean          @default(false)
  subtasks         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  feedItem         FeedItem?        @relation(fields: [feedItemId], references: [id], onDelete: SetNull)
  assignments      TaskAssignment[]
  logs             DailyLog[]
  observations    Observation[]

  @@index([animalCategory])
  @@index([category])
  @@index([feedItemId])
}

model DailyLog {
   id                Int       @id @default(autoincrement())
  date              DateTime
  taskId            Int
  userId            Int
  completed         Boolean   @default(false)
  quantityGrams     Int?
  notes             String?
  completedSubtasks Json?
  photoUrl          String?
  ApprovalStatus    String?

  // supervisor workflow
  approvalStatus ApprovalStatus @default(PENDING)
  approvedById   Int?
  approvedAt     DateTime?
  supervisorNote String?
  reviewedAt     DateTime?
  reviewedById   Int?
  reviewedBy     User?          @relation("ReviewedLogs", fields: [reviewedById], references: [id])

  task   Task @relation(fields: [taskId], references: [id])
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, taskId, userId]) // prevent duplicate log entries for same task/user/day
  @@index([date])
}

model FeedItem {
  id          Int     @id @default(autoincrement())
  name        String  @unique // e.g., "Pig Feed"
  unit        String  @default("g") // store as grams internally
  reorderRule String? // free text: "Chicken feed only per 25 bags of 20kg"
  active      Boolean @default(true)

  stockGrams Int @default(0) // current stock in grams

  minOrderKg      Int? // e.g. 500
  orderMultipleKg Int? // e.g. 500 (must order in multiples of this)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  tasks     Task[]
  rations   FeedRation[]
  movements InventoryMovement[]
}

model FeedRation {
  id                   Int    @id @default(autoincrement())
  feedItemId           Int
  species              String // e.g., "pig"
  gramsPerAnimalPerDay Int
  animalCount          Int    @default(1)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedItem FeedItem @relation(fields: [feedItemId], references: [id])

  @@index([species])
}

model InventoryMovement {
  id         Int      @id @default(autoincrement())
  feedItemId Int
  date       DateTime
  deltaGrams Int
  reason     String
  refType    String?
  refId      Int?
  lineKey    String?   // NEW: lets one DailyLog create multiple movements
  userId     Int?

  createdAt DateTime @default(now())

  feedItem FeedItem @relation(fields: [feedItemId], references: [id])

  @@unique([refType, refId, lineKey])
  @@index([date])
  @@index([feedItemId])
}

model Observation {
  id            Int      @id @default(autoincrement())
  date          DateTime
  title         String
  description   String?
  severity      String
  animalTag     String?
  status        String   @default("OPEN") // OPEN, RESOLVED, IGNORED

  taskId        Int?
  task          Task?    @relation(fields: [taskId], references: [id])

  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id])

  photos        ObservationPhoto[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ObservationPhoto {
  id            Int         @id @default(autoincrement())
  observationId Int
  observation   Observation @relation(fields: [observationId], references: [id], onDelete: Cascade)

  filePath  String // "/uploads/obs/xxx.jpg"
  fileName  String
  mimeType  String
  sizeBytes Int

  createdAt DateTime @default(now())

  @@index([observationId])
}

model TaskAssignment {
  id         Int      @id @default(autoincrement())
  taskId     Int
  userId     Int
  active     Boolean  @default(true)
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

